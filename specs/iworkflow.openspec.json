        "heartbeat_interval_s": {
          "type": "integer",
          "description": "Expected frequency of progress updates.",
          "default": 60
        },
        "gate": {
          "type": "object",
          "description": "Abort guard evaluated on the agent result.",
          "properties": {
            "field": {
              "type": "string"
            },
            "abort_on": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            }
          },
          "additionalProperties": false
