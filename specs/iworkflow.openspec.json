        "instructions": {
          "type": "object",
          "description": "Planner hints for sub-agents (worktree/branch/gh). Not enforced by the engine.",
          "properties": {
            "run_in_worktree": {
              "type": "string",
              "description": "\"current\" or worktree name."
            },
            "branch": {
              "type": "string",
              "description": "\"reuse\", \"none\", or \"new:<name>\"."
            },
            "gh": {
              "type": "string",
