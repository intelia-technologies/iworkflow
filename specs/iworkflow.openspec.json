  "capabilities": {
    "schema-validation": {
      "summary": "Engine-side validation of agent schema outputs before DONE.",
      "description": "When AgentSpec.schema is defined, the runner validates the complete provider value before recording the agent as DONE. Schema mismatches are treated like provider failures so failover, required semantics, and compound-step ok aggregation remain deterministic.",
      "requirements": [
        "When AgentSpec.schema is not null and a provider returns a value, the engine validates the full value with minijsonschema.validate before emitting or recording DONE.",
        "When validation fails, the engine emits schema_mismatch with label, provider, and why, records the attempt as SCHEMA_MISMATCH, and tries the next routed or preferred provider.",
        "If every provider mismatches, required=true raises a workflow error for a sequential agent and required=false continues with value=null and ok=false.",
        "Parallel and pipeline subagents validate independently; any invalid subresult has ok=false and makes the aggregate step ok=false.",
        "Ledger records include schema_ok: true when a schema-defined result passed validation, false when schema-defined execution exhausted without a valid result, and null when no schema was requested."
      ]
    },
    "tmux-isolation": {
      "summary": "Per-run tmux socket isolation for Claude interactive workers.",
      "description": "ClaudeInteractiveProvider can run all tmux commands through a dedicated socket name. Runner assigns the canonical socket iw_{run_id} to ClaudeInteractiveProvider instances and the workflow executor tears down that server when the run finishes.",
      "requirements": [
        "When ClaudeInteractiveProvider.tmux_socket is set, every internal tmux invocation uses argv prefix [\"tmux\", \"-L\", \"<tmux_socket>\"] before the subcommand.",
        "When ClaudeInteractiveProvider.tmux_socket is null, tmux uses the default server without a -L flag.",
        "Runner injects tmux_socket=\"iw_{run_id}\" into ClaudeInteractiveProvider instances during construction.",
        "Runner.teardown_tmux() destroys the per-run server with tmux -L iw_{run_id} kill-server and suppresses missing-server errors.",
        "The workflow executor invokes runner.teardown_tmux() during finalization on success, abort, error, or cancellation."
      ]
    },
    "worktree-isolation": {
      "summary": "Automatic git worktree isolation for write-capable parallel and pipeline agents.",
      "description": "Write-capable AgentSpecs inside parallel and pipeline steps run in a deterministic temporary git worktree keyed by run_id, step_id, and agent_id. The executor validates write_paths inside that worktree, squashes successful changes back into the base working tree, and removes the worktree in all outcomes.",
      "requires_git": true,
      "applies_to": [
        "parallel",
        "pipeline"
      ],
      "requirements": [
        "The executor creates one worktree under the system temp directory for each AgentSpec in a parallel or pipeline step where sandbox is not read-only or tools includes write.",
        "Read-only agents in the same compound step continue to run in the runner default cwd without worktree creation.",
        "When isolated, git dirty-path checks and write_paths validation run with the worktree as cwd.",
        "On successful write-capable completion, the executor stages and commits worktree changes, applies git merge --squash from the base cwd, commits staged base changes with git commit --no-edit, and returns the agent result only after consolidation.",
        "The executor removes isolated worktrees with git worktree remove --force in a finally block for success, provider failure, validation failure, and exceptions.",
        "If the base cwd is not inside a git repository, a write-capable parallel or pipeline agent fails before any provider call with a descriptive WorkflowError."
      ]
    },
    "interactive-gates": {
      "summary": "Human-in-the-loop checkpoints with PAUSED resume-safe execution.",
      "description": "Checkpoint steps pause unattended runs with a pending_input payload, resume deterministically from a validated output JSON file, or resolve inline through an injected interactive resolver. Confirm checkpoints require explicit affirmative approval.",
      "requirements": [
        "A checkpoint step without a valid resolution pauses the workflow with status PAUSED and emits checkpoint_pending.",
        "A checkpoint output file is JSON-decoded and validated against schema before the step completes.",
        "Invalid or ambiguous checkpoint resolution keeps the run paused and does not execute dependent steps.",
        "An injected interactive resolver may return a valid resolution inline; the engine persists it to output and continues without relaunching.",
        "mode=confirm advances only on an explicit affirmative value such as {\"approved\": true} or \"go\"."
      ]
    }
  },
  "actions": {
    "workflows.list": {
      "summary": "List available workflows/recipes.",
      "input": {
        "type": "object",
        "properties": {
          "recipe_dir": {
            "type": "string",
            "description": "Host recipe dir (default .iworkflow/recipes)."
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "workflows": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "params": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "required": [
          "workflows"
        ],
        "additionalProperties": false
      }
    },
    "workflows.run": {
      "summary": "Run a workflow synchronously (CLI/MCP/SDK).",
      "input": {
        "type": "object",
        "properties": {
          "workflow": {
            "type": "string",
            "description": "Recipe name to run."
          },
          "spec": {
            "$ref": "#/types/WorkflowSpec",
            "description": "Inline dynamic workflow spec."
          },
          "goal": {
            "type": "string",
            "description": "Shortcut to fan_synthesize recipe."
          },
          "params": {
            "type": "object",
            "additionalProperties": true
          },
          "limits": {
            "$ref": "#/types/Limits"
          },
          "caps": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Per-provider concurrency caps."
          },
          "run_id": {
            "type": "string"
          },
          "journal_dir": {
            "type": "string"
          },
          "recipe_dir": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "output": {
        "$ref": "#/types/WorkflowRunBundle"
      }
    },
    "workflows.start": {
      "summary": "Start a workflow asynchronously (non-blocking).",
      "input": {
        "$ref": "#/actions/workflows.run/input"
      },
      "output": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "started",
              "unknown_done"
            ]
          }
        },
        "required": [
          "run_id",
          "status"
        ],
        "additionalProperties": false
      }
    },
    "workflows.stream": {
      "summary": "Stream workflow events (long-poll style).",
      "input": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string"
          },
          "after": {
            "type": "integer",
            "default": 0
          },
          "block_s": {
            "type": "number",
            "default": 5
          }
        },
        "required": [
          "run_id"
        ],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "next_after": {
            "type": "integer"
          }
        },
        "required": [
          "run_id",
          "status",
          "events",
          "next_after"
        ],
        "additionalProperties": false
      }
    },
    "workflows.poll": {
      "summary": "Poll a workflow snapshot.",
      "input": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string"
          }
        },
        "required": [
          "run_id"
        ],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "bundle": {
            "$ref": "#/types/WorkflowRunBundle"
          }
        },
        "required": [
          "run_id",
          "status"
        ],
        "additionalProperties": true
      }
    },
    "graph.generate": {
      "summary": "Generate a workflow diagram (Mermaid/HTML/publish).",
      "input": {
        "type": "object",
        "properties": {
          "workflow": {
            "type": "string"
          },
          "spec": {
            "$ref": "#/types/WorkflowSpec"
          },
          "html_path": {
            "type": "string"
          },
          "publish": {
            "type": "boolean",
            "default": false
          },
          "mermaid": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "html_path": {
            "type": "string"
          },
          "publish_url": {
            "type": "string"
          },
          "mermaid": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "examples": {
    "recipe.complex_security_audit": {
      "summary": "Multi-stage security audit (gate → parallel threat modeling → pipeline scans → looped remediation → supervisor).",
      "workflow": "complex_security_audit",
      "params": {
        "modules": [
          "auth-service",
          "billing-core",
          "gateway-api"
        ],
        "codebase_description": "Payments + OAuth backend"
      }
    },
    "dynamic.loop.decider": {
      "summary": "Loop until a decider says STOP, collecting findings.",
      "spec": {
        "name": "loop_decider_demo",
        "params": {
          "subject": "payments service"
        },
        "steps": [
          {
            "id": "sweep",
            "kind": "loop",
            "max_iterations": 3,
            "until": {
              "agent": {
                "prompt": "Found {{loop.collected}}. STOP when done.",
                "stop_when": "STOP",
                "prefer": [
                  "gemini"
                ]
              }
            },
            "collect": {
              "from": "find",
              "path": "findings",
              "dedup_by": "title"
            },
            "body": [
              {
                "id": "find",
                "kind": "agent",
                "schema": {
                  "type": "object",
                  "required": [
                    "findings"
                  ],
                  "properties": {
                    "findings": {
                      "type": "array"
                    }
                  }
                },
                "prompt": "Find NEW issues in {{params.subject}} not in {{loop.collected}}; focus on {{loop.decision.missing}}.",
                "prefer": [
                  "codex",
                  "gemini"
                ]
              }
            ]
          }
        ],
        "output": "{{steps.sweep.value}}"
      }
    }
  }
}
