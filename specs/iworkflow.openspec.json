      "type": "object",
      "description": "JSON Schema draft-07+ object. Used inline or by name.",
      "additionalProperties": true
    },
    "Limits": {
      "type": "object",
      "description": "Safety policy (optional; omit to use engine defaults).",
      "properties": {
        "allowed_sandboxes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allow_tools": {
          "type": "boolean"
        },
        "max_total_agent_calls": {
          "type": "integer",
          "minimum": 1
        },
        "max_parallel_width": {
          "type": "integer",
          "minimum": 1
        },
        "max_pipeline_items": {
          "type": "integer",
          "minimum": 1
        },
        "max_loop_depth": {
          "type": "integer",
          "minimum": 1
        },
        "max_loop_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "max_supervisions": {
          "type": "integer",
          "minimum": 0
