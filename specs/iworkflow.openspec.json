            "type": "string"
          },
          "description": "Provider preference order."
        },
        "role": {
          "type": "string",
          "description": "Optional role hint for routing."
        },
        "model": {
          "type": "string",
          "description": "Provider/model override."
        },
        "sandbox": {
          "type": "string",
          "description": "Sandbox name (default read-only)."
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tool allowlist (honored only if policy allow_tools=true)."
        },
        "timeout_s": {
          "type": "integer",
          "description": "Max duration for this agent call.",
          "default": 300
